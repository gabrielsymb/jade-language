{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,
    "lib": [
      "ES2022"
    ]
  },
  "include": [
    "lexer/**/*",
    "ast/**/*",
    "parser/**/*",
    "semantic/**/*",
    "codegen/**/*",
    "formatter/**/*",
    "linter/**/*",
    "*.ts",
    "*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "vitest.config.ts",
    "tests/**/*"
  ]
}
