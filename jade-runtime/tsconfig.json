{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "lib": [
      "ES2022",
      "DOM"
    ]
  },
  "include": [
    "core/**/*",
    "persistence/**/*",
    "apis/**/*",
    "stdlib/**/*",
    "ui/**/*",
    "pwa/**/*",
    "*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "vitest.config.ts",
    "tests/**/*"
  ]
}
